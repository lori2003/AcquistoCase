# Copia in `backend/.env` (NON committare il file reale).
# Tutte le chiavi vivono SOLO in variabili d'ambiente.

# --- AI (opzionale): senza chiave si usa il report di fallback locale ---
ACQUISTOCASE_OPENROUTER_API_KEY=
ACQUISTOCASE_OPENROUTER_MODEL=openai/gpt-4o-mini

# --- OpenStreetMap (gratuiti, con rate-limit; richiedono User-Agent custom) ---
ACQUISTOCASE_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
ACQUISTOCASE_OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
ACQUISTOCASE_USER_AGENT=AcquistoCase/0.1 (https://github.com/lori2003/AcquistoCase)

# --- Frontend ---
# URL del backend FastAPI, usato dal client Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
